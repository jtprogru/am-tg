{
  "uid": "am-tg-health",
  "title": "am-tg / Service Health",
  "tags": ["am-tg"],
  "timezone": "browser",
  "schemaVersion": 39,
  "editable": true,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "source",
        "label": "Source",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(am_tg_alerts_received_total, source)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "refId": "A", "expr": "up{job=\"am-tg\"}", "instant": true }],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "noValue": "DOWN"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Delivery success (5m)",
      "description": "Share of Telegram sendMessage calls that succeeded",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 4, "y": 0, "w": 5, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(am_tg_telegram_sends_total{outcome=\"success\",source=~\"$source\"}[5m])) / clamp_min(sum(rate(am_tg_telegram_sends_total{source=~\"$source\"}[5m])), 1e-9)"
        }
      ],
      "options": { "colorMode": "value", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "decimals": 1,
          "noValue": "no traffic",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.9 }, { "color": "green", "value": 0.99 }]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Webhooks (5m rate)",
      "description": "POST /alert requests per second",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 9, "y": 0, "w": 5, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(am_tg_http_requests_total{handler=\"/alert\"}[5m]))" }
      ],
      "options": { "colorMode": "none", "graphMode": "area" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "decimals": 2, "noValue": "0" },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Alerts received (5m rate)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 14, "y": 0, "w": 5, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(am_tg_alerts_received_total{source=~\"$source\"}[5m]))" }
      ],
      "options": { "colorMode": "none", "graphMode": "area" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "decimals": 2, "noValue": "0" },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "p95 send latency (5m)",
      "description": "Telegram sendMessage duration including retries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 19, "y": 0, "w": 5, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(am_tg_telegram_send_duration_seconds_bucket{source=~\"$source\"}[5m])))"
        }
      ],
      "options": { "colorMode": "value", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "noValue": "no traffic",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP responses by status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(am_tg_http_requests_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 8, "showPoints": "never" }
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "/^2../" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byRegexp", "options": "/^4../" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
          { "matcher": { "id": "byRegexp", "options": "/^5../" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Alerts received by source / status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (source, status) (rate(am_tg_alerts_received_total{source=~\"$source\"}[5m]))",
          "legendFormat": "{{source}} / {{status}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 8, "showPoints": "never" }
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "HTTP /alert latency quantiles",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum by (le) (rate(am_tg_http_request_duration_seconds_bucket{handler=\"/alert\"}[5m])))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(am_tg_http_request_duration_seconds_bucket{handler=\"/alert\"}[5m])))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum by (le) (rate(am_tg_http_request_duration_seconds_bucket{handler=\"/alert\"}[5m])))", "legendFormat": "p99" }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 0, "showPoints": "never" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p50" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "super-light-blue" } }] },
          { "matcher": { "id": "byName", "options": "p95" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] },
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "dark-blue" } }] }
        ]
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Telegram send p95 by source",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, source) (rate(am_tg_telegram_send_duration_seconds_bucket{source=~\"$source\"}[5m])))",
          "legendFormat": "{{source}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 0, "showPoints": "never" }
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Telegram sends by outcome",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (outcome) (rate(am_tg_telegram_sends_total{source=~\"$source\"}[5m]))",
          "legendFormat": "{{outcome}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 8, "showPoints": "never" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "success" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "timeout" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "network_error" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
          { "matcher": { "id": "byName", "options": "retry_exhausted" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "client_error" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "dark-red" } }] }
        ]
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Permanent rejections (1h)",
      "description": "client_error = Telegram permanently rejects messages (bad chat_id / revoked bot token). Anything above zero needs attention.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 20, "w": 4, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(am_tg_telegram_sends_total{outcome=\"client_error\",source=~\"$source\"}[1h]))"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "noValue": "0",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        },
        "overrides": []
      }
    },
    {
      "id": 12,
      "type": "bargauge",
      "title": "Alerts per source (1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 20, "w": 8, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (source) (increase(am_tg_alerts_received_total{source=~\"$source\"}[1h]))",
          "legendFormat": "{{source}}",
          "instant": true
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "basic",
        "showUnfilled": true,
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      }
    }
  ]
}
