# Copy to .env and fill in. Referenced as ${VAR} from sources.yaml
# (see sources.example.yaml) and loaded by docker compose / make run.
#
# Every variable your sources.yaml references MUST be present here —
# a missing one is a startup error.

# Default bot token (sources.yaml: defaults.bot_token)
TG_BOT_TOKEN=123456:replace-me

# One bearer token per source (sources.yaml: sources[].token)
AM_TG_TOKEN_PROD=generate-a-long-random-token
AM_TG_TOKEN_STAGING=another-long-random-token

# Per-source bot override, only if used in sources.yaml (sources[].bot_token)
# TG_BOT_TOKEN_STAGING=123457:replace-me
